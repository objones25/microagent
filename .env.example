# Anthropic API key — required for agent runs
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret for WebSocket token auth (wss://.../ws/run?token=<secret>)
# If unset, all connections are allowed (only safe behind CORS on trusted origins)
API_SECRET_TOKEN=

# Allowed CORS origins, comma-separated. Defaults to * if unset.
CORS_ORIGINS=https://owenbeckettjones.com,https://www.owenbeckettjones.com

# Maximum number of simultaneous agent runs (default: 5)
MAX_CONCURRENT_RUNS=5

# Sentry DSN for error tracking — optional, Sentry is disabled if unset
SENTRY_DSN=

# Port to listen on — Railway injects this automatically (default: 8000)
PORT=8000
